:34.424433Z","shell.execute_reply.started":"2024-05-26T04:28:33.479025Z","shell.execute_reply":"2024-05-26T04:28:34.423443Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"X_train_cp = cp.asarray(X_train_scaled)\nX_test_scaled = cp.asarray(X_test_scaled)","metadata":{"execution":{"iopub.status.busy":"2024-05-26T04:30:06.733804Z","iopub.execute_input":"2024-05-26T04:30:06.734142Z","iopub.status.idle":"2024-05-26T04:30:07.528926Z","shell.execute_reply.started":"2024-05-26T04:30:06.734113Z","shell.execute_reply":"2024-05-26T04:30:07.527837Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"num_of_classes=10\ndef one_hot_encode(labels, num_classes):\n    # labels: array de cupy con etiquetas enteras, num_classes: número total de clases\n    # Crea un array de ceros con forma (número de muestras, número de clases)\n    one_hot = cp.zeros((labels.size, num_classes), dtype=cp.float32)\n    # Asigna 1 a la posición de cada etiqueta\n    one_hot[cp.arange(labels.size), labels] = 1\n    return one_hot\n\n# Suponiendo que y_train es un array de cupy de etiquetas enteras del dataset CIFAR-10\ny_train_cp = cp.asarray(y_train)  # Asegúrate de que y_train es un array de cupy\ny_train_onehot = one_hot_encode(y_train_cp, num_of_classes)","metadata":{"_uuid":"bc0c0d21-cb46-42de-8574-cb338d3707cc","_cell_guid":"cb58ba88-8ee8-4dba-b00a-4ee1c182a51f","collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2024-05-26T04:30:22.569693Z","iopub.execute_input":"2024-05-26T04:30:22.570299Z","iopub.status.idle":"2024-05-26T04:30:22.577055Z","shell.execute_reply.started":"2024-05-26T04:30:22.570262Z","shell.execute_reply":"2024-05-26T04:30:22.576123Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Base del modelo","metadata":{}},{"cell_type":"code","source":"import cupy as cp\n\nclass DenseLayer:\n    def __init__(self, input_size, output_size, l2_lambda=0.01):\n        self.weights = cp.random.randn(output_size, input_size) * cp.sqrt(2. / input_size)  # He initialization\n        self.bias = cp.zeros(output_size)\n        self.l2_lambda = l2_lambda\n    \n    def forward(self, input):\n        self.input = input\n        return cp.dot(self.weights, input) + self.bias[:, None]\n    \n    def backward(self, output_gradient, learning_rate):\n        weights_gradient = cp.dot(output_gradient, self.input.T)\n        bias_gradient = cp.sum(output_gradient, axis=1, keepdims=False)\n        \n        # Regularización L2\n        weights_gradient += self.l2_lambda * self.weights\n        \n        self.weights -= learning_rate * weights_gradient\n        self.bias -= learning_rate * bias_gradient\n        \n        return cp.dot(self.weights.T, output_gradient)\n\n\nclass ReLULayer:\n    def forward(self, input):\n        self.input = input\n        return cp.maximum(0, input)\n    \n    def backward(self, output_gradient):\n        return output_gradient * (self.input > 0)\n\nclass SoftmaxLayer:\n    def forward(self, input):\n        self.input = input\n        e = cp.exp(input - cp.max(input, axis=0, keepdims=True))\n        self.output = e / cp.sum(e, axis=0, keepdims=True)\n        return self.output\n    \n    def backward(self, output_gradient):\n        return output_gradient\n\ndef cross_entropy_loss(y_pred, y_true):\n    m = y_true.shape[1]\n    epsilon = 1e-9\n    log_probs = cp.log(y_pred + epsilon)\n    loss = -cp.sum(y_true * log_probs) / m\n    return loss\n\ndef backward_cross_entropy_loss(y_pred, y_true):\n    return (y_pred - y_true) / y_true.shape[1]  # Dividir por el número de muestras en el batch\n","metadata":{"_uuid":"d3263796-eeef-4bba-b94a-e4a4f037aa46","_cell_guid":"64ac67e1-6012-4a12-924f-9417836b36e1","execution":{"iopub.status.busy":"2024-05-26T04:30:24.848639Z","iopub.execute_input":"2024-05-26T04:30:24.849251Z","iopub.status.idle":"2024-05-26T04:30:24.861516Z","shell.execute_reply.started":"2024-05-26T04:30:24.849221Z","shell.execute_reply":"2024-05-26T04:30:24.860621Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Tecnicas de mejora","metadata":{}},{"cell_type":"code","source":"def adjust_learning_rate(learning_rate, epoch, decay_rate=0.1, decay_epoch=50):\n    \"\"\"Decays learning rate by a factor every decay_epoch epochs.\"\"\"\n    return learning_rate * (decay_rate ** (epoch // decay_epoch))\n\nclass DropoutLayer:\n    def __init__(self, drop_prob):\n        self.drop_prob = drop_prob\n\n    def forward(self, input, train=True):\n        if train:\n            self.mask = cp.random.binomial(1, 1 - self.drop_prob, size=input.shape) / (1 - self.drop_prob)\n            return input * self.mask\n        else:\n            return input\n\n    def backward(self, output_gradient):\n        return output_gradient * self.mask","metadata":{"execution":{"iopub.status.busy":"2024-05-26T04:30:27.723862Z","iopub.execute_input":"2024-05-26T04:30:27.724174Z","iopub.status.idle":"2024-05-26T04:30:27.730926Z","shell.execute_reply.started":"2024-05-26T04:30:27.724151Z","shell.execute_reply":"2024-05-26T04:30:27.730028Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def train(X_train, y_train, layers, epochs, learning_rate, batch_size):\n    num_samples = X_train.shape[1]\n    clip_value = 1.0\n    for epoch in range(epochs):\n        # Ajustar la tasa de aprendizaje\n        lr = adjust_learning_rate(learning_rate, epoch)\n\n        epoch_loss = 0.0\n        for start_idx in range(0, num_samples, batch_size):\n            end_idx = min(start_idx + batch_size, num_samples)\n            X_batch = X_train[:, start_idx:end_idx]\n            y_batch = y_train[:, start_idx:end_idx]\n\n            # Propagación hacia adelante\n            activations = [X_batch]\n            for layer in layers:\n                activations.append(layer.forward(activations[-1]))\n                if cp.any(cp.isnan(activations[-1])):\n                    print(f\"Nan found in layer {layer} activations\")\n                    return  # Stop training if nan is found\n\n            # Calcular la pérdida\n            probs = activations[-1]\n            loss = cross_entropy_loss(probs, y_batch)\n            if cp.isnan(loss):\n                print(\"Nan found in loss\")\n                return  # Stop training if nan is found\n\n            epoch_loss += loss * (end_idx - start_idx)\n\n            # Retropropagación del error\n            gradient = backward_cross_entropy_loss(probs, y_batch)\n            gradient = cp.clip(gradient, -clip_value, clip_value)\n            for layer in reversed(layers[:-1]):\n                if isinstance(layer, DenseLayer):\n                    gradient = layer.backward(gradient, lr)\n                else:\n                    gradient = layer.backward(gradient)\n\n        epoch_loss /= num_samples\n        print(f\"Epoch {epoch+1}, Loss: {epoch_loss}\")","metadata":{"execution":{"iopub.status.busy":"2024-05-26T04:30:29.348927Z","iopub.execute_input":"2024-05-26T04:30:29.349605Z","iopub.status.idle":"2024-05-26T04:30:29.360735Z","shell.execute_reply.started":"2024-05-26T04:30:29.349574Z","shell.execute_reply":"2024-05-26T04:30:29.359944Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Aplanar y transponer X_train_cp antes de entrenar\nX_train_flat = X_train_cp.reshape(X_train_cp.shape[0], -1).T\ny_train_onehot = y_train_onehot.T  # Esto es solo necesario si las dimensiones no son compatibles","metadata":{"_uuid":"039638ec-b851-4831-a99a-198a69be381a","_cell_guid":"d3ad4573-2215-4310-868e-da89d530797f","collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2024-05-26T04:30:31.00329Z","iopub.execute_input":"2024-05-26T04:30:31.004207Z","iopub.status.idle":"2024-05-26T04:30:31.008541Z","shell.execute_reply.started":"2024-05-26T04:30:31.004177Z","shell.execute_reply":"2024-05-26T04:30:31.007576Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Verificar las dimensiones antes de entrenar\nprint(\"Shape of X_train_flat:\", X_train_flat.shape)\nprint(\"Shape of y_train_onehot:\", y_train_onehot.shape)","metadata":{"_uuid":"65bfa0e2-ba02-48a4-a2f0-eeb0fd6b348e","_cell_guid":"12479c3f-4761-4069-af60-d122e42bde26","collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2024-05-26T04:57:58.066641Z","iopub.execute_input":"2024-05-26T04:57:58.067331Z","iopub.status.idle":"2024-05-26T04:57:58.072006Z","shell.execute_reply.started":"2024-05-26T04:57:58.067296Z","shell.execute_reply":"2024-05-26T04:57:58.071157Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Ejemplo de uso en la arquitectura\nlayers = [\n    DenseLayer(3072, 512), ReLULayer(),\n    DenseLayer(512, 256), ReLULayer(),\n    DenseLayer(256, 128), ReLULayer(),\n    DenseLayer(128, 64), ReLULayer(),\n    DenseLayer(64, 10), SoftmaxLayer()\n]\n# Configuración de parámetros para el entrenamiento\nepochs = 300\nlearning_rate = 0.001\nbatch_size = 64  \n\n# Ejecución del entrenamiento\ntrain(X_train_flat, y_train_onehot, layers, epochs, learning_rate, batch_size)","metadata":{"_uuid":"0afd8495-ddab-44f1-b551-94d10be46e3f","_cell_guid":"9567c9e3-ca67-482f-932b-5fd1f81db8db","collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2024-05-26T05:02:39.254418Z","iopub.execute_input":"2024-05-26T05:02:39.255091Z","iopub.status.idle":"2024-05-26T05:02:40.600492Z","shell.execute_reply.started":"2024-05-26T05:02:39.255061Z","shell.execute_reply":"2024-05-26T05:02:40.599543Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"print(y_train_onehot[:1])","metadata":{"execution":{"iopub.status.busy":"2024-05-25T09:14:31.495579Z","iopub.execute_input